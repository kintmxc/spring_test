<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.spring_test.mapper.ProductCollocationMapper">
    <select id="getCollocationsByProductId" resultType="com.example.spring_test.entity.ProductCollocation">
        SELECT * FROM product_collocation
        WHERE product_id = #{productId}
        ORDER BY score DESC
        LIMIT #{limit}
    </select>
    
    <select id="getTopCollocations" resultType="com.example.spring_test.entity.ProductCollocation">
        SELECT * FROM product_collocation
        ORDER BY score DESC
        LIMIT #{limit}
    </select>
</mapper>